# Copy to .env and fill in. The app calls these live; missing keys surface a clear error.
TWELVELABS_API_KEY=
ANTHROPIC_API_KEY=

# Optional overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
# The brand index enables only Marengo (clip embeddings for the pre-filter).
# pegasusModel is the ANALYZE model: Pegasus 1.5 runs via analyze-by-asset_id
# (real OCR of on-screen text) — it is NOT enabled on the index.
TWELVELABS_MARENGO_MODEL=marengo3.0
TWELVELABS_PEGASUS_MODEL=pegasus1.5

# On-brief LABEL thresholds (Pegasus on-brief %, applied at compliance time)
RELEVANCE_READY_THRESHOLD=60
RELEVANCE_PENDING_THRESHOLD=35
# Marengo embeddings pre-filter bar (mean cosine of the top-10% most on-brand
# clips). 0.115 sits in the gap between genuine BoJ creatives (0.129–0.144) and a
# same-category competitor cream (0.105), so off-brand submissions are rejected too.
RELEVANCE_PREFILTER_THRESHOLD=0.115
